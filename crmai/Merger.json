    {
      "parameters": {
        "jsCode": "// All selected submissions from Supabase\nconst submissions = items.map(i => i.json);\n\n// ---- Safety checks ----\nif (!Array.isArray(submissions) || submissions.length < 2) {\n  throw new Error(\"Need at least 2 submissions to merge\");\n}\n\n// Ensure required fields exist\nsubmissions.forEach(s => {\n  if (!s.id || !s.submitted_at) {\n    throw new Error(\"Each submission must have id and submitted_at\");\n  }\n});\n\n// ---- Sort by submitted_at (oldest first) ----\nsubmissions.sort(\n  (a, b) => new Date(a.submitted_at) - new Date(b.submitted_at)\n);\n\n// ---- Canonical record ----\nconst canonical = submissions[0];\nconst canonicalId = canonical.id;\n\n// ---- Helpers ----\nconst uniq = arr =>\n  [...new Set(arr.filter(v => v !== null && v !== \"\"))];\n\n// ---- Merge logic ----\nconst mergedPhones = uniq(\n  submissions.map(s => s.primary_phone)\n);\n\nconst mergedSources = uniq(\n  submissions.map(s => s.source_platform)\n);\n\nconst mergedEvents = uniq(\n  submissions.map(s => s.source_event)\n);\n\nconst mergedPayloads = submissions\n  .map(s => s.raw_payload)\n  .filter(Boolean);\n\n// ---- Output items ----\nconst output = [];\n\n// 1️⃣ Canonical UPDATE payload\noutput.push({\n  json: {\n    type: \"canonical\",\n    canonical_id: canonicalId,\n\n    primary_phone: mergedPhones,\n    source_platform: mergedSources,\n    source_event: mergedEvents,\n\n    submitted_at: canonical.submitted_at,\n    raw_payload: {\n      payloads: mergedPayloads\n    },\n\n    merge_reason: \"manual_merge_ui\"\n  }\n});\n\n// 2️⃣ Child rows → merged_into\nsubmissions.slice(1).forEach(s => {\n  output.push({\n    json: {\n      type: \"child\",\n      id: s.id,\n      merged_into: canonicalId\n    }\n  });\n});\n\nreturn output;\n"
      },
