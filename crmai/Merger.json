    {
      "parameters": {
        "jsCode": "function normalize(v) {\n  if (!v) return [];\n\n  if (Array.isArray(v)) {\n    return v.flatMap(x => {\n      if (typeof x === \"string\" && x.startsWith(\"[\")) {\n        try { return JSON.parse(x); } catch { return []; }\n      }\n      return x;\n    });\n  }\n\n  if (typeof v === \"string\") return [v];\n\n  return [];\n}\n\nconst canonicalId = $json.canonical_id || $json.id;\n\nif (!canonicalId) {\n  throw new Error(\"Missing canonical_id\");\n}\n\nreturn [{\n  json: {\n    id: canonicalId,              // 👈 THIS IS THE KEY FIX\n    primary_phone: normalize($json.primary_phone),\n    source_platform: normalize($json.source_platform),\n    source_event: normalize($json.source_event),\n    raw_payload: typeof $json.raw_payload === \"string\"\n      ? JSON.parse($json.raw_payload)\n      : $json.raw_payload,\n    merge_reason: \"manual_merge_ui\"\n  }\n}];\n"
      },
